---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

const dateVal = post.data.published_at || post.data.pubDate || new Date();
const formattedDate = dateVal.toLocaleDateString("ja-JP", {
	year: 'numeric',
	month: '2-digit',
	day: '2-digit'
});

// 本文から最初の画像を抽出する
const body = post.body;
const imgRegex = /!\[.*?\]\((.*?)\)|<img.*?src=["'](.*?)["']/i;
const match = body.match(imgRegex);
const firstImage = match ? (match[1] || match[2]) : undefined;

// heroImage が指定されていれば優先し、なければ本文の最初の画像
const ogImage = post.data.heroImage || firstImage;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${post.data.title} - MUHO's Blog`} description={post.data.snippet || post.data.description || ""} image={ogImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
		<style>
			body {
				font-family: 'Inter', 'Noto Sans JP', sans-serif;
				background-color: #f8fafc;
				color: #334155;
				margin: 0;
				padding: 0;
			}

			main {
				max-width: 768px; /* max-w-screen-md */
				margin: 0 auto;
				padding: 2rem 1rem;
			}

			.back-link {
				display: inline-block;
				margin-bottom: 1.5rem;
				color: #2563eb;
				text-decoration: none;
				font-weight: 500;
				transition: color 0.2s ease, transform 0.2s ease;
			}

			.back-link:hover {
				color: #1d4ed8;
				transform: translateX(-4px);
			}

			.article-container {
				background: #ffffff;
				border: 1px solid #e2e8f0;
				border-radius: 12px;
				padding: 2rem;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
			}

			.article-title {
				font-size: 2.25rem;
				font-weight: 800;
				color: #1e293b;
				margin-top: 0;
				margin-bottom: 0.5rem;
				line-height: 1.3;
			}

			.article-date {
				font-size: 0.95rem;
				color: #64748b;
				display: block;
				margin-bottom: 2rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid #e2e8f0;
			}

			/* Styled typography for the post body */
			.article-body {
				font-size: 1.1rem;
				line-height: 1.8;
				color: #334155;
			}

			.article-body :global(h1),
			.article-body :global(h2),
			.article-body :global(h3),
			.article-body :global(h4) {
				color: #1e293b;
				font-weight: 700;
				margin-top: 2rem;
				margin-bottom: 1rem;
			}

			.article-body :global(h1) { font-size: 1.75rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; }
			.article-body :global(h2) { font-size: 1.5rem; border-bottom: 1px solid #f1f5f9; padding-bottom: 0.25rem; }
			.article-body :global(h3) { font-size: 1.25rem; }

			.article-body :global(p) {
				margin-bottom: 1.25rem;
			}

			.article-body :global(ul),
			.article-body :global(ol) {
				margin-bottom: 1.25rem;
				padding-left: 1.5rem;
			}

			.article-body :global(li) {
				margin-bottom: 0.5rem;
			}

			.article-body :global(code) {
				font-family: monospace;
				background-color: #f1f5f9;
				padding: 0.2rem 0.4rem;
				border-radius: 4px;
				font-size: 0.95em;
				color: #0f172a;
			}

			.article-body :global(pre) {
				background-color: #0f172a;
				color: #f8fafc;
				padding: 1rem;
				border-radius: 8px;
				overflow-x: auto;
				margin-bottom: 1.25rem;
			}

			.article-body :global(pre code) {
				background-color: transparent;
				padding: 0;
				border-radius: 0;
				color: inherit;
				font-size: 0.9em;
			}

			.article-body :global(blockquote) {
				border-left: 4px solid #3b82f6;
				background-color: #eff6ff;
				padding: 0.75rem 1rem;
				margin: 0 0 1.25rem 0;
				border-radius: 0 8px 8px 0;
				font-style: italic;
				color: #1e3a8a;
			}

			.article-body :global(a) {
				color: #2563eb;
				text-decoration: none;
				border-bottom: 1px dashed #2563eb;
			}

			.article-body :global(a:hover) {
				color: #1d4ed8;
				border-bottom-style: solid;
			}

			.article-body :global(img) {
				display: block;
				max-width: 100%;
				height: auto;
				border-radius: 8px;
				margin: 1.5rem auto;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
			}

			.tag-container {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				align-items: center;
				font-size: 0.9rem;
				color: #64748b;
				margin-top: 2rem;
				padding-top: 1rem;
				border-top: 1px solid #e2e8f0;
			}

			.tag-label {
				font-weight: 600;
			}

			.tag-badge {
				background-color: #f1f5f9;
				color: #475569;
				padding: 0.2rem 0.6rem;
				border-radius: 6px;
				font-weight: 500;
				text-decoration: none;
				border: 1px solid #cbd5e1;
				transition: all 0.2s ease;
			}

			.tag-badge:hover {
				background-color: #3b82f6;
				color: #ffffff;
				border-color: #3b82f6;
				transform: translateY(-1px);
			}

			@media (max-width: 640px) {
				main {
					padding: 1.5rem 0.75rem;
				}
				.article-container {
					padding: 1.5rem;
				}
				.article-title {
					font-size: 1.75rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a href="/" class="back-link">← 戻る</a>
			
			<article class="article-container">
				<h1 class="article-title">{post.data.title}</h1>
				<time class="article-date" datetime={dateVal.toISOString()}>
					{formattedDate}
				</time>

				<div class="article-body">
					<Content />
				</div>

				{post.data.tag && post.data.tag.length > 0 && (
					<div class="tag-container">
						<span class="tag-label">タグ:</span>
						{post.data.tag.map((tag) => (
							<a href={`/posts/search/${tag}`} class="tag-badge">
								{tag}
							</a>
						))}
					</div>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
